# ─── 안티그래비티 환경변수 템플릿 ───
# 실제 값은 .env 파일에 저장 (이 파일은 예시용, 커밋됨)
# cp .env.example .env  → 값 채우기

# ========== AI API ==========
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ========== 네이버 ==========
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCH_AD_API_KEY=
NAVER_SEARCH_AD_SECRET_KEY=
NAVER_SEARCH_AD_CUSTOMER_ID=

# 네이버 카페 크롤링용 로그인 쿠키 (부계정 권장, 정지 위험 있음)
# Chrome → 네이버 로그인 → F12 → Application → Cookies → naver.com
# NID_AUT와 NID_SES 값 복사
NAVER_NID_AUT=
NAVER_NID_SES=

# ========== 노션 ==========
NOTION_TOKEN=
KEYWORD_DB_ID=
CONTENT_DB_ID=

# ========== 쓰레드(Threads) ==========
# Threads Graph API (자기 계정 발행용)
THREADS_APP_ID=
THREADS_APP_SECRET=

# 쓰레드 레퍼런스 크롤링용 인스타그램 로그인 쿠키 (부계정 필수, 정지 위험)
# Chrome → instagram.com 로그인 → F12 → Application → Cookies → instagram.com
# sessionid, ig_did, csrftoken 등 복사 후 JSON 형식으로 입력
# 예: {"sessionid":"1234%3Aabc","ig_did":"A1B2C3","csrftoken":"xyz"}
THREADS_COOKIE_JSON=

# (선택) 쿠키 추출한 브라우저의 User-Agent. 없으면 기본값 사용
THREADS_USER_AGENT=

# ========== 유튜브 ==========
YOUTUBE_CLIENT_SECRET_FILE=
YOUTUBE_TOKEN_FILE=

# ========== 기타 ==========
CAPCUT_DRAFTS_DIR=
REDIRECT_BASE_URL=http://localhost:8000
